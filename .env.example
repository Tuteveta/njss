# ─────────────────────────────────────────────
# NJSS Web — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to version control
# ─────────────────────────────────────────────

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=njss_user
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_NAME=njss_db

# JWT — REQUIRED in production. Must be at least 32 random characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_A_LONG_RANDOM_SECRET_HERE

# Admin — only used on first database initialisation
ADMIN_INITIAL_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# App
NODE_ENV=production
